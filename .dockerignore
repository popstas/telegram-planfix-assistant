.pytest_cache/
.coverage*
htmlcov/
.tox/
.nox/
.mypy_cache/
.ruff_cache/

# Editor / OS noise
.idea/
.vscode/
.DS_Store
*.swp

# VCS
.git/
.gitignore

# Docs not needed in the image
docs/
tests/
